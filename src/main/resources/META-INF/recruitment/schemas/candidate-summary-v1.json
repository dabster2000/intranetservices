{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summaryParagraph","practiceMatchScore","levelMatchScore","consultingPotential","concerns","evidenceCitations"],
  "properties": {
    "summaryParagraph":    {"type": "string"},
    "practiceMatchScore":  {"type": "number"},
    "levelMatchScore":     {"type": "number"},
    "consultingPotential": {"type": "number"},
    "concerns":            {"type": "array", "items": {"type": "string"}},
    "evidenceCitations":   {"type": "array", "items": {"type": "string"}}
  }
}
