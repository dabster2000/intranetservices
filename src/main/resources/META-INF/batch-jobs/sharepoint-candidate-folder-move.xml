<?xml version="1.0" encoding="UTF-8"?>
<job id="sharepoint-candidate-folder-move" xmlns="http://xmlns.jcp.org/xml/ns/javaee" version="1.0">
    <!--
    SharePoint Candidate Folder Move Batch Job

    Purpose:
    Drains the SharePoint move queue: copies the per-candidate recruitment
    folder to the new employee's home folder and removes the recruitment-side
    folder. Runs out-of-band from the candidate-convert HTTP transaction
    because Graph API calls cannot be rolled back (spec §11.6).

    Processing Flow:
    1. Find candidates with status=HIRED and sharepoint_move_status=PENDING
    2. For each: resolve username from converted_user_uuid
    3. Delegate to SharePointCandidateFolderService.copyAndDeleteOnHire()
    4. Persist returned status (COMPLETED, PARTIAL, FAILED) on the candidate row

    Schedule:
    Runs every 5 minutes via BatchScheduler

    Similar to:
    nextsign-status-sync.xml (proven pattern for queued post-commit operations)
    -->

    <listeners>
        <listener ref="jobMonitoringListener"/>
    </listeners>

    <step id="drain-pending-folder-moves">
        <listeners>
            <listener ref="stepProgressListener"/>
        </listeners>

        <batchlet ref="sharepointCandidateFolderMoveBatchlet"/>
    </step>
</job>
