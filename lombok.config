# Stop Lombok from searching parent directories (the monorepo root) for additional config.
config.stopBubbling = true

# Preserve pre-1.18.40 behaviour: Lombok copies Jackson annotations (e.g. @JsonProperty,
# @JsonIgnore, @JsonFormat) from fields onto the accessors/builder methods it generates.
# Lombok 1.18.40 changed the DEFAULT to no longer copy them. This project ran on 1.18.38 (copy
# enabled) and uses field-level Jackson annotations extensively (93 @JsonProperty / 85 @JsonIgnore
# source files, including the security-sensitive password/cpr @JsonIgnore fields), so we keep the
# prior behaviour to make the 1.18.38 -> 1.18.46 upgrade serialization-neutral. Remove this flag
# only after a deliberate review of Jackson (de)serialization across the DTOs and entities.
lombok.copyJacksonAnnotationsToAccessors = true
